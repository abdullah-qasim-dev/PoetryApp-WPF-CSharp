<Window x:Class="SE_project_2025.AnnounceContestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SE_project_2025"
        mc:Ignorable="d"
        Title="AnnounceContestWindow" Height="450" Width="800">
    <Window.Background>
        <ImageBrush ImageSource="images/home_background.jpg"/>
    </Window.Background>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Announce Poetry Contest" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Title:" FontWeight="Bold"/>
            <TextBox Name="txtTitle" Height="25"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Theme:" FontWeight="Bold"/>
            <TextBox Name="txtTheme" Height="25"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Start Date:" FontWeight="Bold"/>
                <DatePicker Name="dpStartDate"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="End Date:" FontWeight="Bold"/>
                <DatePicker Name="dpEndDate"/>
            </StackPanel>
        </StackPanel>

        <Button Margin="0,20,0,0" Grid.Row="4" Content="Announce Contest" Width="150" Height="30"
                Click="AnnounceContest_Click" HorizontalAlignment="Center"/>
    </Grid>

</Window>
