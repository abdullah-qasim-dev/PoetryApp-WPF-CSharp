<Window x:Class="SE_project_2025.settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SE_project_2025"
        mc:Ignorable="d"
        Title="Settings" 
Height="350" Width="420"
WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
WindowStyle="SingleBorderWindow"
ShowInTaskbar="True">

    <!-- Background Image -->
    <Window.Background>
        <ImageBrush ImageSource="/images/Home_background.jpg" Stretch="Fill"/>
    </Window.Background>

    <Grid>
        <StackPanel Margin="20,40,20,0" VerticalAlignment="Top">


            <!-- Change Username Button -->
            <Border Background="White"  Width="200"  BorderThickness="0" Margin="0,8,0,0">
                <Button  Click="btn_change_username" Content="Change Username" Width="200" Height="40" FontSize="14" FontWeight="Bold" 
                        Background="Transparent" BorderThickness="0" Foreground="Black"
                         />
            </Border>

            <!-- Change Email Button -->
            <Border Background="White"  Width="200"  BorderThickness="0" Margin="0,8,0,0">
                <Button  Click="btn_change_email" Content="Change Email" Width="200" Height="40" FontSize="14" FontWeight="Bold" 
                        Background="Transparent" BorderThickness="0" Foreground="Black"/>
            </Border>

            <!-- Change Password Button -->
            <Border Background="White"  Width="200"  BorderThickness="0" Margin="0,8,0,0">
                <Button Click="btn_change_pass" Content="Change Password" Width="200" Height="40" FontSize="14" FontWeight="Bold" 
                        Background="Transparent" BorderThickness="0" Foreground="Black"/>
            </Border>

            <!-- Logout Button -->
            <Border Background="#DC143C" Width="150"  BorderThickness="0" Margin="0,80,0,0">
                <Button Click="btnlogout_click" Content="Log Out" Width="90" Height="35" FontSize="12" FontWeight="Bold" 
                        Background="Transparent" BorderThickness="0" Foreground="White"/>
            </Border>

        </StackPanel>
    </Grid>
</Window>
