<Window x:Class="SE_project_2025.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Poet's Sanctuary - Register" 
        Height="500" Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True">
    <Grid Background="Beige">

        <!-- Background Image -->
        <Image Source="/images/Home_background.jpg" Stretch="Fill" Panel.ZIndex="-1"/>

        <!-- Logo Section -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,5,0,0">
            <Image Source="Images/logo.jpeg" Width="70" Height="70">
                <Image.Clip>
                    <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35"/>
                </Image.Clip>
            </Image>
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="Black" Margin="0,5,0,0" TextAlignment="Center">
                شہرِ سُخن
            </TextBlock>
        </StackPanel>

        <!-- Registration Form -->
        <Border Background="#FFFFD1A1" CornerRadius="10" Width="260" Padding="10"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,110,0,0" Height="340">
            <StackPanel>
                <TextBlock Text="Register an Account" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>

                <!-- First Name -->
                <TextBlock Text="First Name:" Foreground="Black" FontWeight="Bold" Margin="0,4,0,2"/>
                <Border Background="White" CornerRadius="10" BorderThickness="0">
                    <TextBox x:Name="txtFirstName" Width="240" Height="24"
                             Foreground="Black" FontSize="11" Padding="4"
                             Background="Transparent" BorderThickness="0"/>
                </Border>

                <!-- Username -->
                <TextBlock Text="User Name (Unique):" Foreground="Black" FontWeight="Bold" Margin="0,4,0,2"/>
                <Border Background="White" CornerRadius="10" BorderThickness="0">
                    <TextBox x:Name="txtUserName" Width="240" Height="24"
                             Foreground="Black" FontSize="11" Padding="4"
                             Background="Transparent" BorderThickness="0"/>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email:" Foreground="Black" FontWeight="Bold" Margin="0,4,0,2"/>
                <Border Background="White" CornerRadius="10" BorderThickness="0">
                    <TextBox x:Name="txtEmail" Width="240" Height="24"
                             Foreground="Black" FontSize="11" Padding="4"
                             Background="Transparent" BorderThickness="0"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Password:" Foreground="Black" FontWeight="Bold" Margin="0,4,0,2"/>
                <Border Background="White" CornerRadius="10" BorderThickness="0">
                    <PasswordBox x:Name="txtPassword" Width="240" Height="24"
                                 Foreground="Black" FontSize="11" Padding="4"
                                 Background="Transparent" BorderThickness="0"/>
                </Border>

                <!-- Error Message for Password -->
                <TextBlock x:Name="passBlc" Foreground="Red" FontWeight="Bold" Visibility="Collapsed"/>

                <!-- Confirm Password -->
                <TextBlock Text="Confirm Password:" Foreground="Black" FontWeight="Bold" Margin="0,4,0,2"/>
                <Border Background="White" CornerRadius="10" BorderThickness="0">
                    <PasswordBox x:Name="txtConfirmPassword" Width="240" Height="24"
                                 Foreground="Black" FontSize="11" Padding="4"
                                 Background="Transparent" BorderThickness="0"/>
                </Border>

                <!-- Register Button -->
                <Button Content="Register" Background="Brown" Foreground="White" Width="90" Height="28" 
                        HorizontalAlignment="Center" Margin="0,10,0,0" Click="Register_Click"/>

                <!-- Already have an account? -->
                <TextBlock Foreground="Black" TextAlignment="Center" Margin="10,4,10,0">
                    <Run Text="Already have an account? "/>
                    <Hyperlink Click="Login_click"><Run Text="Login"/></Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
