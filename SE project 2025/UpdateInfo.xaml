<Window x:Class="SE_project_2025.UpdateInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Information" Height="350" Width="420"
                ResizeMode="NoResize"

        WindowStartupLocation="CenterScreen">



    <!-- Background Image -->
    <Window.Background>
        <ImageBrush ImageSource="/images/Home_background.jpg" Stretch="Fill"/>
    </Window.Background>
    
    <Grid >
        
        <StackPanel Margin="20" VerticalAlignment="Center">

            <TextBlock x:Name="lblHeading" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="Black"/>

            <TextBlock  x:Name="lblHeading1" Margin="0,5,0,-5" />

            <TextBox x:Name="txtOldValue" Margin="0,5" />
            
            <TextBlock  x:Name="lblHeading2" Margin="0,5,0,-5"/>

            <TextBox x:Name="txtNewValue" Margin="0,5" />

            <Button Content="Update" Click="btnUpdate_Click" Margin="0,15,0,0" Background="DarkGreen" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
