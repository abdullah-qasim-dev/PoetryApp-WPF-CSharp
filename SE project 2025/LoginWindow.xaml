<Window x:Class="SE_project_2025.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Poet's Sanctuary - Login" 
        Height="500" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True">
    <Grid Background="Beige">

        <!-- Background Image -->
        <Image Source="/images/Home_background.jpg" Stretch="Fill" Panel.ZIndex="-1"/>

        <!-- Logo -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,5,0,0">
            <!-- Logo -->
            <Image Source="Images/logo.jpeg" Width="90" Height="90">
                <Image.Clip>
                    <EllipseGeometry Center="45,45" RadiusX="45" RadiusY="45"/>
                </Image.Clip>
            </Image>

            <!-- Urdu Text -->
            <TextBlock FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,5,0,0" TextAlignment="Center">
        شہرِ سُخن
            </TextBlock>
        </StackPanel>

        <!-- Left Side: Text Section -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="50,180,400,0">
            <TextBlock Text="📜 Welcome to Poet’s Sanctuary – Where Words Find Their Soul!" 
                       FontSize="16" FontWeight="Bold" Foreground="Brown" TextWrapping="Wrap"/>
            <TextBlock Text="Discover the timeless beauty of Urdu and Punjabi poetry, curated just for you." 
                       FontSize="14" FontStyle="Italic" FontWeight="Bold" Foreground="Maroon" TextWrapping="Wrap" Margin="0,20,0,0" Width="247"/>
        </StackPanel>

        <!-- Right Side: Login Form -->
        <Border Background="#FFFFD1A1" CornerRadius="10" Width="246" 
                HorizontalAlignment="Right" Margin="0,162,42,42">
            <StackPanel Margin="20">
                <TextBlock Text="Login to Account" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>

                <TextBlock Text="Username*" FontWeight="Bold" FontSize="12" Margin="0,10,0,0"/>
                <Border Background="White" CornerRadius="10" BorderThickness="0">
                    <TextBox Name="txtUsername" Width="208" Height="25" Background="Transparent" BorderThickness="0" Foreground="Black" FontSize="11" Padding="4"/>
                </Border>

                <TextBlock Text="Password*" FontWeight="Bold" FontSize="12" Margin="0,10,0,0"/>
                <Border Background="White" CornerRadius="10" BorderThickness="0">
                    <PasswordBox Name="txtPassword" Width="208" Height="25" Background="Transparent" BorderThickness="0" Foreground="Black" FontSize="11" Padding="4"/>
                </Border>

                <!-- User/Admin Selection -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <RadioButton Name="rdoUser" Content="User" IsChecked="True" Margin="0,0,10,0"/>
                    <RadioButton Name="rdoAdmin" Content="Admin"/>
                </StackPanel>

                <Button Content="Login" Background="Brown" Foreground="White" Width="120" Height="30" 
                        HorizontalAlignment="Center" Margin="0,15,0,0" Click="btnLogin_Click"/>

                <TextBlock Foreground="Black" TextAlignment="Center" Margin="10,5,10,0">
                    <Run Text="Don't have an account? "/>
                    <Hyperlink Click="Register_Click"><Run Text="Register"/></Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
