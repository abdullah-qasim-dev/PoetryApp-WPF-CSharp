<Window x:Class="SE_project_2025.mainpage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SE_project_2025"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="Home" Height="510" Width="800">
    <Window.Background>
        <ImageBrush ImageSource="images/home_background.jpg"/>
    </Window.Background>
    <Grid>
        <DockPanel LastChildFill="False" VerticalAlignment="Top" Background="Transparent">

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,5,0,0">
                <!-- Logo -->
                <Image Source="Images/logo.jpeg" Width="90" Height="90">
                    <Image.Clip>
                        <EllipseGeometry Center="45,45" RadiusX="35" RadiusY="35"/>
                    </Image.Clip>
                </Image>

                <!-- Urdu Text -->
                <TextBlock FontSize="16" FontWeight="Bold" Foreground="Black" Margin="0,0,0,0" TextAlignment="Center">
شہرِ سُخن
                </TextBlock>
            </StackPanel>


            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" HorizontalAlignment="Right">
                <Button x:Name="button_poets" Content="Poets" FontSize="16" Background="Transparent" BorderThickness="0" Foreground="Black" Margin="10,0" FontFamily="Dubai" FontWeight="Bold" Click="Poet_btn_click"/>
                <Button Click="about_btn_click"  Content="About" Background="Transparent" BorderThickness="0" Foreground="Black" FontSize="16" FontWeight="Bold" FontFamily="Dubai" Margin="10,0"/>
                <Button Content="Contact Us" Background="Transparent" BorderThickness="0" Foreground="Black" FontSize="16" FontWeight="Bold" FontFamily="Dubai" Margin="0,0,40,0"/>
                <!-- Search Bar with Icon -->
                <Grid Width="180" Height="30">
                    <TextBox x:Name="searchtextbox" Width="180" Height="30"  Padding="10,0,35,0" 
                     Background="White" BorderBrush="Gray" BorderThickness="1" 
                     FontSize="14" FontWeight="Bold" Foreground="Gray"
                     VerticalContentAlignment="Center" HorizontalContentAlignment="Left"/>
                    <Button Click="Search_btn_click" Background="Transparent" BorderThickness="0" Width="30" Height="30"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,0,0"> 
                        <Image Source="images/search.png" Width="15" Height="15"/>
                    </Button>
                </Grid>
                <Button x:Name="btnProfile" Background="Transparent" BorderThickness="0" Margin="10,0,0,0"
        Click="btnProfile_Click">
                    <Image Source="images/profile_icon.png" Width="35" Height="35"/>
                </Button>

            </StackPanel>
        </DockPanel>


        
        


        <Border Background="Transparent"  CornerRadius="0" Padding="0" Margin="30,110,40,258">
            <StackPanel>
                <!-- Title -->
                

                <!-- Horizontal Poets List -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <!-- Poet 1 -->
                    <Button Click="Ghalib_Click" Background="Transparent" BorderThickness="0" Margin="10,5,30,10" Cursor="Hand">
                        <StackPanel>
                            <Image Source="images/ghalib.png" Width="80" Height="80" Stretch="Fill">
                                <Image.Clip>
                                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                </Image.Clip>
                            </Image>
                            <TextBlock Text="Mirza Ghalib" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black"/>
                        </StackPanel>
                    </Button>

                    <!-- Poet 2 -->
                    <Button Click="Faiz_Click" Background="Transparent" BorderThickness="0" Margin="10,5,30,10" Cursor="Hand">
                        <StackPanel>
                            <Image Source="images/faiz.jpg" Width="80" Height="80" Stretch="Fill">
                                <Image.Clip>
                                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                </Image.Clip>
                            </Image>
                            <TextBlock Text="Faiz Ahmad Faiz" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black"/>
                        </StackPanel>
                    </Button>

                    <!-- Poet 3 -->
                    <Button Click="Jaun_Click" Background="Transparent" BorderThickness="0" Margin="10,5,30,10" Cursor="Hand">
                        <StackPanel>
                            <Image Source="images/jaun.jpeg" Width="80" Height="80" Stretch="Fill">
                                <Image.Clip>
                                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                </Image.Clip>
                            </Image>
                            <TextBlock Text="Jaun Elia" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black"/>
                        </StackPanel>
                    </Button>

                    <!-- Poet 4 -->
                    <Button Click="Mir_Click" Background="Transparent" BorderThickness="0" Margin="10,5,30,10" Cursor="Hand">
                        <StackPanel>
                            <Image Source="images/mir.jpg" Width="80" Height="80" Stretch="Fill">
                                <Image.Clip>
                                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                </Image.Clip>
                            </Image>
                            <TextBlock Text="Mir Taqi Mir" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black"/>
                        </StackPanel>
                    </Button>

                    <!-- Poet 5 -->
                    <Button Click="Faraz_Click" Background="Transparent" BorderThickness="0" Margin="10,5,0,10" Cursor="Hand">
                        <StackPanel>
                            <Image Source="images/fraz.png" Width="80" Height="80" Stretch="Fill">
                                <Image.Clip>
                                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                </Image.Clip>
                            </Image>
                            <TextBlock Text="Ahmad Faraz" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- New Section: Search by Category, Language, and Theme -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,255,0,20">
            <!-- Left Box: Search by Category -->
            <Border Background="Transparent"  CornerRadius="20" Padding="10,5,10,0" Margin="0,0,40,0">
                <StackPanel>
                    <TextBlock Text="Search Poets by Category" FontStyle="Italic" FontSize="12" FontWeight="Bold" TextDecorations="Underline" Margin="0,0,0,10"/>

                    <Button Content="• Nazm" FontStyle="Oblique"  Foreground="White" Background="#A08A68" Margin="0,2"  Click="btn_nazm"/>
                    <Button Content="• Ghazals" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2"  Click="btn_ghazal"/>
                    <Button Content="• Qasida" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2" Click="btn_qasida"/>
                    <Button Content="• Hamd" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2" Click="btn_hamd"/>
                    <Button Content="• Naat" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2" Click="btn_naat"/>
                </StackPanel>

            </Border>

            <!-- Middle Box: Search by Language -->
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Select Language" FontWeight="Bold" FontStyle="Italic" HorizontalAlignment="Center" FontSize="15" Margin="0,40,0,0"/>
                <RadioButton Name="rdo_urdu" Content="Urdu" IsChecked="True" Margin="0,10,10,0"/>
                <RadioButton Name="rdo_punjabi"  Content="Punjabi" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Right Box: Search by Theme -->
            <Border Background="Transparent"  CornerRadius="20" Padding="10,5,10,40" Margin="40,0,0,0">
                <StackPanel Height="176">
                    <TextBlock Text="Search Poets by Theme" FontStyle="Italic" FontSize="12" FontWeight="Bold" TextDecorations="Underline" Margin="0,0,0,10"/>

                    <Button Content="Philosophy" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2"    Click="btn_phil"/>
                    <Button Content="Patriotism" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2" Click="btn_patriotism"/>
                    <Button Content="Love" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2" Click="btn_love"/>
                    <Button Content="Sadness" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2" Click="btn_sad"/>
                    <Button Content="Hopelessness" FontStyle="Oblique" Foreground="White" Background="#A08A68" Margin="0,2" Click="btn_hopelessness"/>
                </StackPanel>

            </Border>
        </StackPanel>

    </Grid>
</Window>