<Window x:Class="SE_project_2025.poems_by_theme"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SE_project_2025"
        mc:Ignorable="d"
                ResizeMode="NoResize"

        WindowStartupLocation="CenterScreen"
        Height="500" Width="400">
    <Window.Background>
        <ImageBrush ImageSource="images/home_background.jpg"/>
    </Window.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <TextBlock FontSize="18" FontStyle="Italic"  FontWeight="Bold" Foreground="Black" Margin="0,5,0,0" TextAlignment="Center">
Poems by Type
            </TextBlock>
            <WrapPanel Name="buttonPanel" Margin="85,10,10,10" />

            <Button Content="⬅ Back"
             Width="120"
             Height="35"
             Margin="10,10,0,0"
             Background="#8B0000"
             Foreground="White"
             FontWeight="Bold"
             Click="back_click_poem_theme"/>
        </StackPanel>
    </ScrollViewer>


</Window>
